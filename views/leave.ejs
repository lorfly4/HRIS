<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manajemen Cuti - HRIS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #1e1e1e; color: #e1e1e1; }
        .card-bg { background-color: #252526; border: 1px solid #333; }
        .input-bg { background-color: #3c3c3c; border: 1px solid #555; color: white; }
        .text-accent { color: #4fc1ff; }
    </style>
</head>
<body class="p-6">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8 border-b border-gray-700 pb-4">
            <div class="flex items-center gap-4">
                <button onclick="window.history.back()" class="bg-gray-800 border border-gray-700 rounded px-4 py-2 text-xs hover:bg-gray-700 transition">← Kembali</button>
                <h1 class="text-2xl font-bold text-accent">Manajemen Cuti</h1>
            </div>
            <button onclick="openLeaveModal()" class="bg-blue-600 px-4 py-2 rounded text-xs font-bold hover:bg-blue-500 transition shadow-lg">+ Ajukan Cuti</button>
        </div>

        <div class="card-bg rounded-xl overflow-hidden shadow-xl border border-gray-800">
            <table class="w-full text-left text-sm">
                <thead class="bg-[#333] text-gray-400 uppercase text-[10px] tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Karyawan</th>
                        <th class="px-6 py-4">Tipe</th>
                        <th class="px-6 py-4">Periode</th>
                        <th class="px-6 py-4 text-center">Status</th>
                        <th class="px-6 py-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody id="leaveTableBody" class="divide-y divide-gray-700">
                    </tbody>
            </table>
        </div>
    </div>

    <div id="modalLeave" class="fixed inset-0 bg-black/80 hidden items-center justify-center p-4 z-50">
        <div class="card-bg w-full max-w-md p-6 rounded-2xl border border-gray-700 shadow-2xl">
            <h3 class="text-xl font-bold mb-6 text-accent">Form Pengajuan Cuti</h3>
            <form id="formLeave" class="space-y-4">
                <div>
                    <label class="text-xs text-gray-400 mb-1 block">Tipe Cuti</label>
                    <select id="type" class="input-bg w-full p-2 rounded text-sm outline-none" required>
                        <option value="annual_leave">Cuti Tahunan</option>
                        <option value="sick_leave">Sakit</option>
                        <option value="other">Lainnya</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs text-gray-400 mb-1 block">Mulai</label>
                        <input type="date" id="start_date" required class="input-bg w-full p-2 rounded text-sm">
                    </div>
                    <div>
                        <label class="text-xs text-gray-400 mb-1 block">Selesai</label>
                        <input type="date" id="end_date" required class="input-bg w-full p-2 rounded text-sm">
                    </div>
                </div>
                <div>
                    <label class="text-xs text-gray-400 mb-1 block">Alasan</label>
                    <textarea id="reason" rows="3" required class="input-bg w-full p-2 rounded text-sm"></textarea>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-gray-700">
                    <button type="button" onclick="closeModal()" class="text-gray-400 text-sm">Batal</button>
                    <button type="submit" class="bg-blue-600 px-6 py-2 rounded-lg font-bold text-sm">Kirim</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('hris_token');
        const user = JSON.parse(localStorage.getItem('hris_user'));
        const userRole = user ? user.role.toLowerCase() : '';

        async function loadLeaves() {
            try {
                // Jika admin/manager, mungkin kamu punya endpoint /api/leave/all-requests 
                // Di sini saya asumsikan load sesuai rute yang kamu miliki
                const res = await fetch('/api/leave/my-requests', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                
                const tbody = document.getElementById('leaveTableBody');
                
                tbody.innerHTML = data.map(l => {
                    // Cek apakah user berhak melakukan Approve/Reject
                    const isAuthorized = (userRole === 'superadmin' || userRole === 'manager');
                    const isPending = l.status === 'pending';

                    return `
                    <tr class="hover:bg-white/5 transition">
                        <td class="px-6 py-4 font-bold text-gray-300">
                            ${l.employee_name || 'Saya'}<br>
                            <span class="text-[10px] text-gray-500 font-normal italic">${l.reason}</span>
                        </td>
                        <td class="px-6 py-4 text-xs">${l.type}</td>
                        <td class="px-6 py-4 text-xs">${new Date(l.start_date).toLocaleDateString()} - ${new Date(l.end_date).toLocaleDateString()}</td>
                        <td class="px-6 py-4 text-center">
                            <span class="px-2 py-1 rounded text-[9px] font-bold uppercase ${
                                l.status === 'pending' ? 'bg-yellow-600/20 text-yellow-500' : 
                                l.status === 'approved' ? 'bg-green-600/20 text-green-500' : 
                                'bg-red-600/20 text-red-500'
                            }">
                                ${l.status}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            ${isAuthorized && isPending ? `
                                <div class="flex gap-2 justify-center">
                                    <button onclick="processLeave(${l.id}, 'approved')" class="bg-green-600/20 text-green-500 border border-green-500/50 px-2 py-1 rounded text-[10px] hover:bg-green-600 hover:text-white transition">Approve</button>
                                    <button onclick="processLeave(${l.id}, 'rejected')" class="bg-red-600/20 text-red-500 border border-red-500/50 px-2 py-1 rounded text-[10px] hover:bg-red-600 hover:text-white transition">Reject</button>
                                </div>
                            ` : `
                                <span class="text-gray-600 text-[10px] italic">Tidak ada aksi</span>
                            `}
                        </td>
                    </tr>
                `}).join('');
            } catch (err) {
                console.error(err);
            }
        }

        async function processLeave(id, status) {
            if(!confirm(`Yakin ingin mengubah status menjadi ${status}?`)) return;

            const res = await fetch(`/api/leave/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status })
            });

            const result = await res.json();
            alert(result.message);
            loadLeaves();
        }

        // Logic submit form tetap sama
        document.getElementById('formLeave').onsubmit = async (e) => {
            e.preventDefault();
            const payload = {
                type: document.getElementById('type').value,
                start_date: document.getElementById('start_date').value,
                end_date: document.getElementById('end_date').value,
                reason: document.getElementById('reason').value
            };

            const res = await fetch('/api/payroll/leave/apply', { // Pastikan route ini benar
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });

            const result = await res.json();
            alert(result.message);
            closeModal();
            loadLeaves();
        };

        function openLeaveModal() { document.getElementById('modalLeave').style.display = 'flex'; }
        function closeModal() { document.getElementById('modalLeave').style.display = 'none'; }

        loadLeaves();
    </script>
</body>
</html>